# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Groq AI API Key
# Get your key from: https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_your-groq-api-key-here

# Google OAuth Credentials
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Note: These same credentials should also be set in:
# 1. Supabase Dashboard → Authentication → Providers → Google
# 2. Supabase Dashboard → Edge Functions → Secrets (GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GROQ_API_KEY)
